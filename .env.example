# Server settings
HOST=0.0.0.0
PORT=3005
DEBUG=true

# Vision backend: "claude_code", "opencode", "ollama", "openai", or "anthropic"
VISION_BACKEND=claude_code

# Ollama settings (if using ollama backend)
OLLAMA_MODEL=llama3.2-vision
OLLAMA_HOST=http://localhost:11434

# OpenAI settings (if using openai backend)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o  # or gpt-4-turbo, gpt-4o-mini, etc.

# Anthropic settings (if using anthropic backend)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514  # or claude-opus-4-20250514, etc.

# TTS settings
TTS_VOICE=en-US-ChristopherNeural

# Paths
PROJECTS_DIR=./projects
CLAUDE_CODE_PATH=claude
OPENCODE_PATH=opencode
